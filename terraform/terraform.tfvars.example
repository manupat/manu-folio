# ════════════════════════════════════════════════════════════════
# terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values.
# Do NOT commit terraform.tfvars to source control.
# ════════════════════════════════════════════════════════════════

project_id = "your-gcp-project-id"
region     = "europe-west1"
name       = "manu-folio"

# Your domain(s) — DNS A record must point to the static IP output
domains = ["kaushikmanu.dev", "www.kaushikmanu.dev"]

# Cloud Run scaling
max_instances = 10

# Resource limits
cpu_limit    = "1000m"
memory_limit = "256Mi"

# Cloud Armor — rate limiting
rate_limit_requests_per_minute = 300

# Cloud Armor — geo-blocking (leave empty [] to allow all)
blocked_countries = []
